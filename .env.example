# Azure DevOps Personal Access Token
# Generate at: https://dev.azure.com/arrivia/_usersSettings/tokens
# Required scopes: Work Items (Read & Write)
ADO_PAT=your_azure_devops_personal_access_token_here

# SMTP Email Settings (Office 365 defaults shown)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@arrivia.com
SMTP_PASS=your_email_password_or_app_password
SMTP_FROM=noreply@arrivia.com

# Server Port (default: 3000)
PORT=3000
